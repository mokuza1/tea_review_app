<h2>質問 <%= @step %> / <%= @total_questions %></h2>

<% progress = (@step.to_f / @total_questions * 100).round %>

<div style="width: 100%; background: #eee; height: 10px; border-radius: 5px;">
  <div
    style="
      width: <%= progress %>%;
      background: #365442;
      height: 10px;
      border-radius: 5px;
      transition: width 0.3s;
    ">
  </div>
</div>

<p>
  <%= @question[:text] %>
</p>

<div>
  <% @question[:options].each do |option| %>

    <%= button_to option,
        answer_diagnostic_path,
        method: :post,
        params: { answer: option } %>

  <% end %>
</div>