<turbo-frame id="diagnostic_modal">

<div
  data-controller="diagnostic-modal"
  data-diagnostic-modal-target="overlay"
  data-action="click->diagnostic-modal#closeBackground"
  class="fixed inset-0 bg-black/40 flex items-center justify-center z-50"
>

  <div class="bg-white p-8 rounded-lg max-w-md w-full relative">

    <button
      data-action="click->diagnostic-modal#close"
      class="absolute top-2 right-2 text-gray-500"
    >
      ✕
    </button>

    <h2 class="text-lg font-bold mb-2">
      質問 <%= @step %> / <%= @total_questions %>
    </h2>

    <% progress = (@step.to_f / @total_questions * 100).round %>

    <div class="w-full bg-gray-200 h-2 rounded mb-4">
      <div
        class="bg-green-700 h-2 rounded"
        style="width:<%= progress %>%">
      </div>
    </div>

    <p class="mb-6">
      <%= @question[:text] %>
    </p>

    <div class="space-y-2">

      <% @question[:options].each_with_index do |option, i| %>

        <%= button_to option[:text],
            answer_diagnostic_path,
            method: :post,
            params: { answer: i },
            form: { data: { turbo_frame: "diagnostic_modal" } },
            class: "w-full border p-2 rounded hover:bg-gray-100" %>

      <% end %>
    </div>

  </div>

</div>

</turbo-frame>