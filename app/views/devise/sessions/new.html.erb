<div class="min-h-screen bg-[#F1EFE9] flex items-start justify-center px-4 pt-24 pb-12">
  <div class="w-full max-w-md">

    <%# --- 再設定メール送信完了メッセージ（カードの外側に配置して視認性を高める） --- %>
    <% if flash[:reset_sent] %>
      <div class="mb-6 p-6 bg-white border-l-4 border-[#365442] shadow-md rounded-r-lg">
        <div class="flex items-center gap-2 mb-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-[#365442]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <p class="text-[#365442] font-bold text-sm tracking-wider">再設定メールを送信しました</p>
        </div>

        <p class="text-xs text-[#8C7B6C] font-bold leading-relaxed mb-4">
          メール内のリンクからパスワードを再設定してください。<br>
          届かない場合は、迷惑メールフォルダやアドレスの入力ミスをご確認ください。
        </p>

        <div class="pt-3 border-t border-[#D6CEC5]/50">
          <%= link_to new_password_path(resource_name, email: flash[:reset_email]),
                class: "text-[13px] font-bold text-[#A75F29] hover:text-[#365442] transition-colors flex items-center gap-1 uppercase tracking-widest" do %>
            <span>再送を希望する</span>
            <span class="text-lg leading-none relative -top-[3px] ml-0.5">›</span>
          <% end %>
        </div>
      </div>
    <% end %>

    <%# --- メインログインカード --- %>
    <div class="bg-white border-2 border-[#B5A89A] rounded-lg shadow-xl p-8 md:p-10">

      <div class="text-center mb-8">
        <h2 class="text-2xl font-serif font-bold text-[#365442] tracking-widest">
          MEMBER LOGIN
        </h2>
        <p class="text-[10px] text-[#8C7B6C] font-bold mt-1 uppercase tracking-[0.2em]">
          <%= t("devise.sessions.new.sign_in") %>
        </p>
        <div class="mt-4 w-10 h-[1px] bg-[#D6CEC5] mx-auto"></div>

        <% if params[:favorite_required] %>
          <div class="mt-6 bg-[#FDFBF9] border border-[#A75F29]/50 text-[#A75F29] px-4 py-3 rounded text-[12px] font-bold tracking-wider">
            ログインするとお気に入り登録ができます。
          </div>
        <% elsif params[:review_required] %>
          <div class="mt-6 bg-[#FDFBF9] border border-[#A75F29]/50 text-[#A75F29] px-4 py-3 rounded text-[12px] font-bold tracking-wider">
            ログインするとレビュー投稿ができます。
          </div>
        <% end %>
      </div>

      <%= form_for(resource,
            as: resource_name,
            url: session_path(resource_name)) do |f| %>

        <div class="mb-5">
          <%= f.label :email, class: "block text-xs font-bold text-[#365442] tracking-widest mb-2 uppercase" %>
          <%= f.email_field :email,
                autofocus: true,
                autocomplete: "email",
                class: "w-full p-3 bg-[#FDFBF9] border-2 border-[#D6CEC5] rounded
                       focus:ring-2 focus:ring-[#365442] focus:border-[#365442] outline-none transition
                       font-normal text-lg text-[#365442] tracking-normal" %>
        </div>

        <div class="mb-5">
          <%= f.label :password, class: "block text-xs font-bold text-[#365442] tracking-widest mb-2 uppercase" %>
          <%= f.password_field :password,
                autocomplete: "current-password",
                class: "w-full p-3 bg-[#FDFBF9] border-2 border-[#D6CEC5] rounded
                       focus:ring-2 focus:ring-[#365442] focus:border-[#365442] outline-none transition
                       font-normal text-lg text-[#365442] tracking-normal" %>
        </div>

        <% if devise_mapping.rememberable? %>
          <div class="flex items-center gap-3 mb-8">
            <%= f.check_box :remember_me,
                  class: "w-4 h-4 rounded border-2 border-[#D6CEC5] text-[#365442] focus:ring-[#365442]" %>
            <%= f.label :remember_me, class: "text-xs font-bold text-[#8C7B6C] tracking-wide" %>
          </div>
        <% end %>

        <div>
          <%= f.submit t("devise.sessions.new.sign_in"),
                class: "w-full bg-[#365442] hover:bg-[#2A4034] text-[#F9F7F2] font-bold font-serif
                       py-4 rounded shadow-lg transition tracking-[0.2em] cursor-pointer" %>
        </div>
      <% end %>

      <div class="relative my-10 text-center">
        <div class="absolute inset-0 flex items-center">
          <span class="w-full border-t border-[#D6CEC5]"></span>
        </div>
        <span class="relative px-4 bg-white text-[10px] font-bold text-[#8C7B6C] tracking-[0.2em] uppercase">
          OR
        </span>
      </div>

      <%# --- Googleログインボタン --- %>
      <%= button_to user_google_oauth2_omniauth_authorize_path,
            data: { turbo: false },
            class: "w-full flex items-center justify-center gap-3 bg-white border-2 border-[#D6CEC5]
                   hover:border-[#365442] hover:bg-[#FDFBF9] text-[#365442] font-bold
                   py-3.5 rounded transition shadow-sm cursor-pointer group" do %>
        
        <%# GoogleのGロゴマーク (SVG) %>
        <svg class="w-5 h-5" viewBox="0 0 24 24">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
        </svg>

        <span class="text-sm font-serif font-bold tracking-[0.15em]">Googleでログイン</span>
      <% end %>

      <%# --- リンクエリア：アカウント登録とパスワード再設定を統合 --- %>
      <div class="mt-10 pt-8 border-t border-[#D6CEC5]/40 text-center space-y-4">
        
        <%# 1. アカウント登録リンク（Deviseの共有リンクから取得する場合、または手動） %>
        <div class="flex flex-col items-center gap-4">
          <% if devise_mapping.registerable? && controller_name != 'registrations' %>
            <%= link_to "新規アカウント登録はこちら", new_registration_path(resource_name),
                  class: "text-[11px] font-bold text-[#8C7B6C] hover:text-[#365442] tracking-[0.15em] transition-colors border-b border-[#D6CEC5] pb-0.5" %>
          <% end %>

          <%# 2. パスワードを忘れた方（デザインを登録リンクと統一） %>
          <% if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
            <%= link_to "パスワードを忘れた方はこちら", new_password_path(resource_name),
                  class: "text-[11px] font-bold text-[#8C7B6C] hover:text-[#365442] tracking-[0.15em] transition-colors border-b border-[#D6CEC5] pb-0.5" %>
          <% end %>
        </div>

      </div>

    </div>
  </div>
</div>
