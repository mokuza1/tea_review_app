<div class="min-h-screen bg-[#F1EFE9] flex items-start justify-center px-4 pt-24 pb-12">
  <div class="w-full max-w-md">

    <%# --- トークン無効・期限切れの場合のエラーメッセージ --- %>
    <% if resource.errors[:reset_password_token].present? %>
      <div class="bg-white border-2 border-[#D6CEC5] rounded-lg shadow-xl p-8 md:p-10">
        <div class="text-center">
          <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-red-50 text-red-400 mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
            </svg>
          </div>
          
          <h2 class="text-xl font-serif font-bold text-[#365442] tracking-widest mb-4">
            LINK INVALID
          </h2>
          
          <p class="text-[12px] text-[#8C7B6C] leading-relaxed mb-8">
            このリンクは有効期限が切れているか、無効です。<br>
            お手数ですが、再度パスワードリセットを行ってください。
          </p>

          <div>
            <%= link_to new_password_path(resource_name), 
                  class: "w-full inline-block bg-[#365442] hover:bg-[#2A4034] text-[#F9F7F2] font-bold py-4 rounded shadow-lg transition tracking-[0.2em] uppercase text-center" do %>
              再設定メールを送る
            <% end %>
          </div>
        </div>
      </div>

    <% else %>

      <%# --- パスワード入力フォーム --- %>
      <div class="bg-white border-2 border-[#B5A89A] rounded-lg shadow-xl p-8 md:p-10">
        
        <div class="text-center mb-8">
          <h2 class="text-2xl font-serif font-bold text-[#365442] tracking-widest">
            RESET PASSWORD
          </h2>
          <p class="text-[10px] text-[#8C7B6C] font-bold mt-1 uppercase tracking-[0.2em]">
            新しいパスワードの設定
          </p>
          <div class="mt-4 w-10 h-[1px] bg-[#D6CEC5] mx-auto"></div>
        </div>

        <%= form_for(resource, as: resource_name, url: password_path(resource_name), method: :put) do |f| %>
          <%# Devise標準エラーの表示 %>
          <%= render "devise/shared/error_messages", resource: resource %>
          <%= f.hidden_field :reset_password_token %>

          <div class="space-y-6">
            <%# 新しいパスワード %>
            <div>
              <%= f.label :password, "新しいパスワード", class: "block text-xs font-bold text-[#365442] tracking-widest mb-2 uppercase" %>
              <%= f.password_field :password, 
                    autofocus: true, 
                    autocomplete: "new-password",
                    class: "w-full p-3 bg-[#FDFBF9] border-2 border-[#D6CEC5] rounded
                           focus:ring-2 focus:ring-[#365442] focus:border-[#365442] outline-none transition
                           font-normal text-lg text-[#365442] tracking-normal" %>
            </div>

            <%# パスワード確認 %>
            <div>
              <%= f.label :password_confirmation, "新しいパスワード（確認用）", class: "block text-xs font-bold text-[#365442] tracking-widest mb-2 uppercase" %>
              <%= f.password_field :password_confirmation, 
                    autocomplete: "new-password",
                    class: "w-full p-3 bg-[#FDFBF9] border-2 border-[#D6CEC5] rounded
                           focus:ring-2 focus:ring-[#365442] focus:border-[#365442] outline-none transition
                           font-normal text-lg text-[#365442] tracking-normal" %>
            </div>

            <div class="pt-2">
              <%= f.submit "パスワードを変更する", 
                    class: "w-full bg-[#365442] hover:bg-[#2A4034] text-[#F9F7F2] font-bold
                           py-4 rounded shadow-lg transition tracking-[0.2em] cursor-pointer" %>
            </div>
          </div>
        <% end %>

        <%# --- フッターリンク --- %>
        <div class="mt-10 pt-8 border-t border-[#D6CEC5]/40 text-center">
          <%= link_to new_session_path(resource_name), 
                class: "text-[11px] font-bold text-[#8C7B6C] hover:text-[#365442] tracking-[0.15em] transition-colors border-b border-[#D6CEC5] pb-0.5 inline-flex items-center gap-1" do %>
            <span class="leading-none">ログインに戻る</span>
          <% end %>
        </div>

      </div>
    <% end %>

  </div>
</div>
