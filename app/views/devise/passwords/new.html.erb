<div class="min-h-screen bg-[#F1EFE9] flex items-start justify-center px-4 pt-24 pb-12">
  <div class="w-full max-w-md">

    <%# =========================
       状態メッセージ
       expired > throttled
    ========================= %>

    <% if params[:expired] %>
      <!-- 有効期限切れ -->
      <div class="mb-6 p-6 bg-white border-l-4 border-[#A75F29] shadow-md rounded-r-lg">
        <p class="text-[#A75F29] font-bold text-sm mb-2">
          リンクの有効期限が切れています
        </p>
        <p class="text-xs text-[#8C7B6C] font-bold leading-relaxed">
          セキュリティ保護のため、再設定用リンクは一定時間で無効になります。<br>
          再度メールアドレスを入力してください。
        </p>
      </div>

    <% elsif params[:throttled] %>
      <div class="mb-6 p-6 bg-white border-l-4 border-red-500 shadow-md rounded-r-lg">
        <p class="text-red-600 font-bold text-sm mb-2">
          リクエスト回数の上限を超えました
        </p>
        <p class="text-xs text-[#8C7B6C] font-bold leading-relaxed">
          しばらく時間をおいてから、再度お手続きをお願いいたします。
        </p>
      </div>
    <% end %>

    <%# =========================
       メインカード
    ========================= %>
    <div class="w-full bg-white border-2 border-[#B5A89A] rounded-lg shadow-xl p-8 md:p-10">

      <!-- ヘッダー -->
      <div class="text-center mb-8">
        <h2 class="text-2xl font-serif font-bold text-[#365442] tracking-widest">
          FORGOT PASSWORD
        </h2>
        <p class="text-[10px] text-[#8C7B6C] font-bold mt-1 uppercase tracking-[0.2em]">
          パスワードの再設定
        </p>
        <div class="mt-4 w-10 h-[1px] bg-[#D6CEC5] mx-auto"></div>

        <div class="mt-6 px-2">
          <p class="text-[13px] text-[#8C7B6C] leading-relaxed font-bold">
            登録済みのメールアドレスを入力してください。<br>
            再設定用のリンクをお送りします。
          </p>
        </div>
      </div>

      <!-- フォーム -->
      <%= form_for(resource, as: resource_name, url: password_path(resource_name)) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <div class="mb-8">
          <%= f.label :email, "メールアドレス",
                class: "block text-xs font-bold text-[#365442] tracking-widest mb-2 uppercase" %>

          <%= f.email_field :email,
                value: params[:email],
                autofocus: true,
                autocomplete: "email",
                placeholder: "example@mail.com",
                class: "w-full p-3 bg-[#FDFBF9] border-2 border-[#D6CEC5] rounded
                       focus:ring-2 focus:ring-[#365442] focus:border-[#365442] outline-none transition
                       text-lg text-[#365442]" %>
        </div>

        <div>
          <%= f.submit "メールを送信",
                class: "w-full bg-[#365442] hover:bg-[#2A4034] text-[#F9F7F2] font-bold
                       py-4 rounded shadow-lg transition tracking-[0.2em]" %>
        </div>
      <% end %>

      <!-- フッター -->
      <div class="mt-10 pt-8 border-t border-[#D6CEC5]/40 text-center">
        <%= link_to new_session_path(resource_name),
              class: "text-[11px] font-bold text-[#8C7B6C] hover:text-[#365442] tracking-[0.15em] transition-colors border-b border-[#D6CEC5] pb-0.5 inline-flex items-center gap-1" do %>
          ログインに戻る
        <% end %>
      </div>

    </div>
  </div>
</div>