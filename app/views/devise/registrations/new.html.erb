<div class="min-h-screen bg-[#F1EFE9] flex items-start justify-center px-4 pt-24 pb-12">
  <div class="w-full max-w-md bg-white border-2 border-[#B5A89A] rounded-lg shadow-xl p-8 md:p-10">

    <%# --- ヘッダー --- %>
    <div class="text-center mb-8">
      <h2 class="text-2xl font-serif font-bold text-[#365442] tracking-widest">
        CREATE ACCOUNT
      </h2>
      <p class="text-[10px] text-[#8C7B6C] font-bold mt-1 uppercase tracking-[0.2em]">
        <%= t("devise.registrations.new.title") %>
      </p>
      <div class="mt-4 w-10 h-[1px] bg-[#D6CEC5] mx-auto"></div>
    </div>

    <%# --- 新規登録フォーム --- %>
    <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
      <div class="mb-6">
        <%= render "devise/shared/error_messages", resource: resource %>
      </div>

      <div class="mb-5">
        <%= f.label :name, class: "block text-xs font-bold text-[#365442] tracking-widest mb-2 uppercase" %>
        <%= f.text_field :name, class: "w-full p-3 bg-[#FDFBF9] border-2 border-[#D6CEC5] rounded focus:ring-2 focus:ring-[#365442] focus:border-[#365442] outline-none transition font-normal text-lg text-[#365442]" %>
      </div>

      <div class="mb-5">
        <%= f.label :email, class: "block text-xs font-bold text-[#365442] tracking-widest mb-2 uppercase" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "w-full p-3 bg-[#FDFBF9] border-2 border-[#D6CEC5] rounded focus:ring-2 focus:ring-[#365442] focus:border-[#365442] outline-none transition font-normal text-lg text-[#365442]" %>
      </div>

      <div class="mb-5">
        <%= f.label :password, class: "block text-xs font-bold text-[#365442] tracking-widest mb-2 uppercase" %>
        <% if @minimum_password_length %>
          <p class="text-[10px] text-[#8C7B6C] mb-2 font-bold italic">* <%= @minimum_password_length %>文字以上</p>
        <% end %>
        <%= f.password_field :password, autocomplete: "new-password", class: "w-full p-3 bg-[#FDFBF9] border-2 border-[#D6CEC5] rounded focus:ring-2 focus:ring-[#365442] focus:border-[#365442] outline-none transition font-normal text-lg text-[#365442]" %>
      </div>

      <div class="mb-8">
        <%= f.label :password_confirmation, class: "block text-xs font-bold text-[#365442] tracking-widest mb-2 uppercase" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "w-full p-3 bg-[#FDFBF9] border-2 border-[#D6CEC5] rounded focus:ring-2 focus:ring-[#365442] focus:border-[#365442] outline-none transition font-normal text-lg text-[#365442]" %>
      </div>

      <div>
        <%= f.submit t("devise.registrations.new.submit"), class: "w-full bg-[#365442] hover:bg-[#2A4034] text-[#F9F7F2] font-serif font-bold py-4 rounded shadow-lg transition tracking-[0.2em] cursor-pointer" %>
      </div>
    <% end %>

    <%# --- 区切り線 --- %>
    <div class="relative my-10 text-center">
      <div class="absolute inset-0 flex items-center">
        <span class="w-full border-t border-[#D6CEC5]"></span>
      </div>
      <span class="relative px-4 bg-white text-[10px] font-bold text-[#8C7B6C] tracking-[0.2em] uppercase">
        OR
      </span>
    </div>

    <%# --- Googleで登録ボタン --- %>
    <%= button_to user_google_oauth2_omniauth_authorize_path, data: { turbo: false }, class: "w-full flex items-center justify-center gap-3 bg-white border-2 border-[#D6CEC5] hover:border-[#365442] hover:bg-[#FDFBF9] text-[#365442] font-bold py-3.5 rounded transition shadow-sm cursor-pointer group" do %>
      <svg class="w-5 h-5" viewBox="0 0 24 24">
        <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
        <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
        <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
        <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
      </svg>
      <span class="text-sm font-serif font-bold tracking-[0.15em]">Googleで登録</span>
    <% end %>

    <%# --- ログインリンクエリア（下部をスッキリ整理） --- %>
    <div class="mt-10 pt-8 border-t border-[#D6CEC5]/40 text-center">
      <%= link_to "すでにアカウントをお持ちの方（ログイン）", new_session_path(resource_name),
            class: "text-[11px] font-bold text-[#8C7B6C] hover:text-[#365442] tracking-[0.15em] transition-colors border-b border-[#D6CEC5] pb-0.5" %>
    </div>

  </div>
</div>