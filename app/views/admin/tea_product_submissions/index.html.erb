<h2 class="text-xl font-bold mb-6">
  承認待ち投稿一覧
</h2>

<table class="w-full border border-gray-200 text-sm">
  <thead class="bg-gray-50">
    <tr>
      <th class="p-2 border">商品名</th>
      <th class="p-2 border">投稿者</th>
      <th class="p-2 border">ステータス</th>
      <th class="p-2 border">申請日時</th>
      <th class="p-2 border">操作</th>
    </tr>
  </thead>

  <tbody>
    <% @submissions.each do |submission| %>
      <tr class="border-t">
        <td class="p-2">
          <%= submission.name.presence || "（未入力）" %>
        </td>

        <td class="p-2">
          <%= submission.user.name %>
        </td>

        <td class="p-2">
          <%= submission.status_i18n %>
        </td>

        <td class="p-2">
          <%= l(submission.created_at, format: :short) %>
        </td>

        <td class="p-2 space-x-2">
          <% if submission.pending? %>

            <%= button_to "却下",
                  reject_admin_tea_product_submission_path(submission),
                  method: :patch,
                  class: "px-3 py-1 bg-red-600 text-white rounded text-xs" %>
          <% end %>

          <%= link_to "詳細",
                admin_tea_product_submission_path(submission),
                class: "text-blue-600 hover:underline text-xs" %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<div class="mt-6">
  <%= paginate @submissions %>
</div>
