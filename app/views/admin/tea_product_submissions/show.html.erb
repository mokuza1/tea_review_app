<h2 class="text-2xl font-bold mb-6">
  承認待ち投稿 詳細
</h2>

<div class="bg-white border rounded-lg p-6 space-y-6">

  <!-- 基本情報 -->
  <div>
    <h3 class="text-lg font-semibold mb-2">基本情報</h3>

    <div class="mb-4">
      <% if @submission.image.attached? %>
        <%= image_tag @submission.image, class: "w-64 h-64 object-cover rounded-lg" %>
      <% else %>
        <div class="w-64 h-64 bg-gray-100 border rounded-lg flex items-center justify-center">
          <span class="text-gray-400">画像なし</span>
        </div>
      <% end %>
    </div>

    <dl class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-4 text-sm">

      <div>
        <dt class="text-gray-500">商品名</dt>
        <dd class="font-medium">
          <%= @submission.name.presence || "未入力" %>
        </dd>
      </div>

      <div>
        <dt class="text-gray-500">投稿者</dt>
        <dd class="font-medium">
          <%= @submission.user.name %>
        </dd>
      </div>

      <div>
        <dt class="text-gray-500">ブランド</dt>
        <dd class="font-medium">
          <%= @submission.brand&.display_name || "未設定" %>
        </dd>
      </div>

      <div>
        <dt class="text-gray-500">茶葉タイプ</dt>
        <dd class="font-medium">
          <%= @submission.enum_i18n(:tea_type) || "未設定" %>
        </dd>
      </div>

      <div>
        <dt class="text-gray-500">カフェイン</dt>
        <dd class="font-medium">
          <%= @submission.enum_i18n(:caffeine_level) || "未設定" %>
        </dd>
      </div>

      <!-- フレーバー -->
      <div class="sm:col-span-2">
        <dt class="text-gray-500">フレーバー</dt>
        <dd class="font-medium">
          <% if @submission.flavors.present? %>
            <% @submission.flavors.group_by(&:flavor_category).each do |category, flavors| %>
              <div class="mb-3">
                <div class="text-sm font-semibold text-gray-600 mb-1">
                  <%= category.name %>
                </div>
                <div class="flex flex-wrap gap-2">
                  <% flavors.each do |flavor| %>
                    <span class="px-3 py-1 bg-blue-100 text-blue-800 rounded-full text-xs">
                      <%= flavor.name %>
                    </span>
                  <% end %>
                </div>
              </div>
            <% end %>
          <% else %>
            未設定
          <% end %>
        </dd>
      </div>

      <!-- 購入場所 -->
      <div class="sm:col-span-2">
        <dt class="text-gray-500">購入場所</dt>
        <dd class="font-medium">
          <% if @submission.purchase_locations.present? %>
            <div class="space-y-2">
              <% @submission.purchase_locations.each do |location| %>
                <div>
                  <span class="inline-block px-2 py-1 bg-gray-100 rounded text-xs mr-2">
                    <%= location.enum_i18n(:location_type) || "未設定" %>
                  </span>
                  <%= location.name %>
                </div>
              <% end %>
            </div>
          <% else %>
            未設定
          <% end %>
        </dd>
      </div>

      <div>
        <dt class="text-gray-500">ステータス</dt>
        <dd class="font-medium">
          <%= @submission.enum_i18n(:status) %>
        </dd>
      </div>

    </dl>
  </div>

  <!-- 説明 -->
  <div>
    <h3 class="text-lg font-semibold mb-2">説明</h3>
    <p class="text-sm text-gray-700 whitespace-pre-wrap">
      <%= @submission.description.presence || "説明なし" %>
    </p>
  </div>

  <!-- 更新申請の場合 -->
  <% if @submission.previous_submission.present? %>
    <% previous = @submission.previous_submission %>

    <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-6 space-y-6">
      <h3 class="text-lg font-semibold">
        変更内容
      </h3>

      <% if @submission.previous_submission&.rejection_reason.present? %>
        <div class="mb-6 p-4 bg-red-50 border border-red-200 rounded-lg">
          <p class="text-sm font-semibold text-red-600 mb-1">⚠️ 前回の却下理由</p>
          <p class="text-sm text-red-800">
            <%= @submission.previous_submission.rejection_reason %>
          </p>
        </div>
      <% end %>

      <%= diff_field "商品名", previous.name, @submission.name %>

      <%= diff_field "説明", previous.description, @submission.description %>

      <%= diff_field "ブランド",
            previous.brand&.display_name,
            @submission.brand&.display_name %>

      <%= diff_field "カフェイン",
            previous.enum_i18n(:caffeine_level),
            @submission.enum_i18n(:caffeine_level) %>

      <%= diff_field "茶葉タイプ",
            previous.enum_i18n(:tea_type),
            @submission.enum_i18n(:tea_type) %>

      <%= diff_flavors previous, @submission %>

      <%= diff_purchase_locations previous, @submission %>
    </div>
  <% end %>

  <!-- 操作 -->
  <div class="flex justify-between pt-4 border-t">

    <%= link_to "一覧に戻る",
          admin_tea_product_submissions_path,
          class: "text-sm text-gray-600 hover:underline" %>

    <% if @submission.pending? %>
      <div class="flex flex-col items-end gap-6">

        <%= button_to "承認",
              approve_admin_tea_product_submission_path(@submission),
              method: :patch,
              class: "px-6 py-2 bg-green-600 text-white rounded font-semibold shadow" %>

        <!-- 却下 -->
        <div class="bg-red-50 border border-red-200 rounded-lg p-4 w-72">

          <%= form_with url: reject_admin_tea_product_submission_path(@submission),
                method: :patch,
                local: true,
                class: "flex flex-col gap-3" do |f| %>

            <%= text_area_tag :rejection_reason,
                  nil,
                  rows: 3,
                  placeholder: "却下理由を入力してください",
                  class: "w-full border rounded p-2" %>

            <%= f.submit "却下する",
                  class: "px-4 py-2 bg-red-600 text-white rounded font-semibold" %>

          <% end %>

        </div>
      </div>
    <% end %>

  </div>

</div>
