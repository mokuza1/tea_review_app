<header class="w-full border-b-2 border-[#D6CEC5] bg-[#F9F7F2] sticky top-0 z-50">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 py-2">

    <input type="checkbox" id="menu-toggle" class="hidden peer">

    <div class="flex items-center justify-between min-h-11">

      <div class="flex-shrink-0">
        <%= link_to root_path, class: "hover:opacity-80 transition block" do %>
          <%= image_tag "logo.png", alt: "みんなの紅茶図鑑", class: "h-9 sm:h-11 w-auto" %>
        <% end %>
      </div>

      <div class="flex items-center gap-3 sm:gap-6">
        
        <%= link_to start_diagnostic_path,
              data: { turbo_frame: "diagnostic_modal" },
              class: "flex items-center gap-1 px-3 py-1.5 bg-white border border-[#C5A065] text-[#A75F29] rounded-full shadow-sm hover:bg-[#FDFBF9] hover:shadow transition-all duration-300 group" do %>
          <span class="text-sm sm:text-sm font-serif font-bold tracking-tighter sm:tracking-widest">
            紅茶診断
          </span>
        <% end %>

        <label for="menu-toggle" class="md:hidden cursor-pointer p-1">
          <div class="space-y-1.5">
            <span class="block w-6 h-0.5 bg-[#365442]"></span>
            <span class="block w-6 h-0.5 bg-[#365442]"></span>
            <span class="block w-4 h-0.5 bg-[#365442] ml-auto"></span>
          </div>
        </label>

        <div class="hidden md:flex items-center space-x-6 text-sm font-medium">
          <%= link_to "ログイン",
                new_user_session_path,
                class: "text-[#433D3C] hover:text-[#365442] font-serif tracking-wider transition" %>

          <%= link_to "新規登録",
                new_user_registration_path,
                class: "rounded bg-[#365442] text-[#F9F7F2] px-5 py-2 font-serif tracking-widest hover:bg-[#2A4034] shadow-sm hover:shadow-md transition duration-300" %>
        </div>
      </div>

    </div>

    <div class="hidden peer-checked:block md:hidden border-t border-[#D6CEC5]/50 mt-2 py-4 space-y-4 text-right">
      <%= link_to "ログイン",
            new_user_session_path,
            class: "block text-[#433D3C] font-serif tracking-wider px-2" %>

      <div class="px-2">
        <%= link_to "新規登録",
              new_user_registration_path,
              class: "inline-block rounded bg-[#365442] text-[#F9F7F2] px-6 py-2.5 font-serif tracking-widest shadow-md" %>
      </div>
    </div>

  </div>
</header>