<div class="min-h-screen bg-[#F9F7F2] text-[#433D3C] flex flex-col font-sans">

  <section class="relative w-full h-[160px] md:h-[220px] mb-28 border-b-4 border-[#365442]">

    <div
      class="absolute inset-0 bg-center bg-cover"
      style="background-image: url('<%= asset_path("home_top.png") %>')">
    </div>

    <div class="absolute inset-0 bg-gradient-to-r from-[#1a2e22]/90 to-[#3b2f2f]/40"></div>

    <div class="relative z-10 h-full flex flex-col items-start justify-center text-left px-8 max-w-4xl mx-auto w-full">

      <div class="w-12 h-1 bg-[#C5A065] mb-4"></div>

      <h1 class="text-3xl md:text-5xl font-serif font-medium text-[#F9F7F2] mb-3 tracking-widest drop-shadow-md">
        みんなの紅茶図鑑
      </h1>

      <p class="text-sm md:text-lg text-white tracking-wider font-light drop-shadow-md">
        Trace & Archive Your Tea Journey
      </p>

    </div>

  </section>

  <section class="px-6 mb-15 -mt-16 relative z-20">
    <div class="max-w-2xl mx-auto bg-[#FBF8F1] shadow-[0_8px_30px_rgb(54,84,66,0.15)] border-2 border-[#D6CEC5] rounded-xl py-5 px-6">

      <%= search_form_for @q,
            url: tea_products_path,
            method: :get,
            class: "flex flex-row sm:flex-row gap-4" do |f| %>

        <%= f.search_field :name_or_brand_name_ja_or_brand_name_en_cont,
              placeholder: "商品名・ブランド名で検索...",
              autocomplete: "off",
              class: "flex-1 p-3 sm:p-4 rounded-lg bg-white border border-[#D6Cec5] font-semibold text-[#26302A] placeholder-gray-400 focus:ring-1 focus:ring-[#365442] focus:border-[#365442] focus:outline-none transition shadow-inner" %>

        <%= f.submit "検索",
              class: "bg-[#365442] hover:bg-[#2A4034] text-[#F9F7F2] font-bold tracking-widest px-4 sm:px-10 py-3 sm:py-4 rounded-lg shadow-md hover:shadow-lg transition duration-300 cursor-pointer border-b-4 border-[#243a2d] text-sm sm:text-base flex-shrink-0" %>

      <% end %>
    </div>
  </section>

  <div data-controller="modal">

    <section class="px-6 mb-24">
      <div class="max-w-xl mx-auto flex flex-col items-center gap-4">

        <%# --- 各パネル共通のデザイン --- %>
        <% [
          { id: "Flavor", label: "FLAVOR", sub: "フレーバーから探す", img: "flavor.png", action: "openFlavor" },
          { id: "Brand", label: "BRAND", sub: "ブランドから探す", img: "brand.png", action: "openBrand" },
          { id: "Type", label: "TYPE", sub: "茶葉タイプから探す", img: "tea_type.png", action: "openTeaType" },
          { id: "Caffeine", label: "CAFFEINE", sub: "カフェイン量から探す", img: "caffeine.png", action: "openCaffeine" }
        ].each do |item| %>

          <button
            type="button"
            data-action="click->modal#<%= item[:action] %>"
            class="relative w-full h-24 md:h-28 overflow-hidden rounded shadow-md hover:shadow-xl hover:-translate-y-0.5 transition-all duration-500 group border-2 border-[#D6CEC5]">

            <%# 背景画像: 縦幅が狭いため、より印象的な部分が映るよう調整 %>
            <div
              class="absolute inset-0 bg-center bg-cover transition-transform duration-1000 group-hover:scale-110"
              style="background-image: url('<%= asset_path(item[:img]) %>')">
            </div>

            <%# オーバーレイ: 少し濃くして文字を浮かび上がらせる %>
            <div class="absolute inset-0 bg-black/30 group-hover:bg-[#365442]/50 transition duration-500"></div>

            <%# ラベル部分: 縦幅に合わせてパディングを調整 %>
            <span
              class="absolute top-1/2 left-6 -translate-y-1/2 z-10 bg-[#F9F7F2]/95 text-[#365442] py-2 px-6 shadow-sm border border-[#D6CEC5] text-left min-w-[160px]">
              <span class="block text-base md:text-lg font-serif font-bold tracking-[0.2em] leading-tight">
                <%= item[:label] %>
              </span>
              <span class="block text-[10px] text-[#8C7B6C] font-bold mt-0.5 whitespace-nowrap">
                <%= item[:sub] %>
              </span>
            </span>

            <%# 内側の装飾枠 %>
            <div class="absolute inset-2 border border-white/20 pointer-events-none rounded-sm"></div>
          </button>

        <% end %>

      </div>
    </section>

    <%= render "shared/search_modal" %>

  </div>
</div>