<turbo-frame id="review_modal">
  <div class="fixed inset-0 flex items-center justify-center bg-black/50 z-50">

    <div class="bg-white p-6 rounded w-[500px]">

      <h2 class="text-lg font-bold mb-4">
        レビューを書く
      </h2>

      <%= form_with model: [@tea_product, @review],
            data: { turbo_frame: "_top" } do |f| %>

        <div class="space-y-4">

          <div>
            <label class="font-semibold">おすすめ度</label><br>
            <% 1.upto(5) do |i| %>
              <%= f.radio_button :overall_rating, i %>
              <%= i %>
            <% end %>
          </div>

          <div>
            <label class="font-semibold">香り</label><br>
            <% 1.upto(5) do |i| %>
              <%= f.radio_button :aroma_rating, i %>
              <%= i %>
            <% end %>
          </div>

          <div>
            <label class="font-semibold">苦味</label><br>
            <% 1.upto(5) do |i| %>
              <%= f.radio_button :bitterness_rating, i %>
              <%= i %>
            <% end %>
          </div>

          <div>
            <label class="font-semibold">濃さ</label><br>
            <% 1.upto(5) do |i| %>
              <%= f.radio_button :strength_rating, i %>
              <%= i %>
            <% end %>
          </div>

          <div>
            <label class="font-semibold">甘さ</label><br>
            <% 1.upto(5) do |i| %>
              <%= f.radio_button :sweetness_rating, i %>
              <%= i %>
            <% end %>
          </div>

          <div>
            <%= f.label :comment, "コメント（任意）", class: "font-semibold" %><br>
            <%= f.text_area :comment,
                  maxlength: 140,
                  rows: 3,
                  class: "w-full border p-2 rounded" %>
          </div>

        </div>

        <div class="mt-6 flex justify-end gap-3">

          <%= link_to "キャンセル",
              tea_product_path(@tea_product),
              data: { turbo_frame: "_top" },
              class: "px-3 py-2 border rounded" %>

          <%= f.submit "投稿する",
              class: "px-4 py-2 bg-[#365442] text-white rounded hover:bg-[#2d4738]" %>

        </div>

      <% end %>

    </div>

  </div>
</turbo-frame>