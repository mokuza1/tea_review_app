<turbo-frame id="review_modal">

  <div
    data-controller="review-modal"
    data-action="click->review-modal#close"
    class="fixed inset-0 flex items-center justify-center bg-black/50 z-50">

    <div
      class="bg-white p-6 rounded w-[500px]"
      data-action="click->review-modal#stop">

      <h2 class="text-lg font-bold mb-4">
        レビューを書く
      </h2>

      <%= form_with model: [@tea_product, @review],
            data: { turbo_frame: "_top" } do |f| %>

        <div class="space-y-4">

          <div>
            <label class="font-semibold">おすすめ度</label><br>
            <div class="rating">
              <% 5.downto(1) do |i| %>
               <%= f.radio_button :overall_rating, i, id: "overall_star#{i}" %>
               <%= f.label "overall_star#{i}" do %>
                 ★
               <% end %>
              <% end %>
            </div>
          </div>

          <div>
            <label class="font-semibold">香り</label><br>
            <div class="rating">
              <% 5.downto(1) do |i| %>
               <%= f.radio_button :aroma_rating, i, id: "aroma_star#{i}" %>
               <%= f.label "aroma_star#{i}" do %>
                 ★
               <% end %>
              <% end %>
            </div>
          </div>

          <div>
            <label class="font-semibold">苦味</label><br>
            <div class="rating">
              <% 5.downto(1) do |i| %>
               <%= f.radio_button :bitterness_rating, i, id: "bitterness_star#{i}" %>
               <%= f.label "bitterness_star#{i}" do %>
                 ★
               <% end %>
              <% end %>
            </div>
          </div>

          <div>
            <label class="font-semibold">濃さ</label><br>
            <div class="rating">
              <% 5.downto(1) do |i| %>
               <%= f.radio_button :strength_rating, i, id: "strength_star#{i}" %>
               <%= f.label "strength_star#{i}" do %>
                 ★
               <% end %>
              <% end %>
            </div>
          </div>

          <div>
            <label class="font-semibold">甘さ</label><br>
            <div class="rating">
              <% 5.downto(1) do |i| %>
               <%= f.radio_button :sweetness_rating, i, id: "sweetness_star#{i}" %>
               <%= f.label "sweetness_star#{i}" do %>
                 ★
               <% end %>
              <% end %>
            </div>
          </div>

          <div>
            <label class="font-semibold">おすすめの飲み方</label>

            <div class="flex gap-4 mt-2">

              <label class="flex items-center gap-1">
                <%= f.check_box :recommended_straight %>
                ストレート
              </label>

              <label class="flex items-center gap-1">
                <%= f.check_box :recommended_milk %>
                ミルク
              </label>

              <label class="flex items-center gap-1">
                <%= f.check_box :recommended_iced %>
                アイス
              </label>

            </div>
          </div>

          <div>
            <%= f.label :comment, "コメント（任意）", class: "font-semibold" %><br>
            <%= f.text_area :comment,
                  maxlength: 140,
                  rows: 3,
                  class: "w-full border p-2 rounded" %>
          </div>

        </div>

        <div class="mt-6 flex justify-end gap-3">

          <%= link_to "キャンセル",
              tea_product_path(@tea_product),
              data: { turbo_frame: "_top" },
              class: "px-3 py-2 border rounded" %>

          <%= f.submit "投稿する",
              class: "px-4 py-2 bg-[#365442] text-white rounded hover:bg-[#2d4738]" %>

        </div>

      <% end %>

    </div>

  </div>
</turbo-frame>