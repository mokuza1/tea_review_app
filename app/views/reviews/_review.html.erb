<div class="border rounded p-3 mb-3">

  <div class="text-sm text-gray-500">
    <%= review.user.name %> /
    <%= review.created_at.strftime("%Y.%m.%d") %>
  </div>

  <div class="mt-2 space-y-1">
    <div>おすすめ度 <span class="text-yellow-500"><%= render_stars(review.overall_rating) %></span></div>
    <div>香り <span class="text-yellow-500"><%= render_stars(review.aroma_rating) %></span></div>
    <div>渋み <span class="text-yellow-500"><%= render_stars(review.bitterness_rating) %></span></div>
    <div>濃さ <span class="text-yellow-500"><%= render_stars(review.strength_rating) %></span></div>
    <div>甘さ <span class="text-yellow-500"><%= render_stars(review.sweetness_rating) %></span></div>
  </div>

  <div class="mt-2 text-sm text-gray-600">

    <% drinks = [] %>
    <% drinks << "ストレート" if review.recommended_straight %>
    <% drinks << "ミルク" if review.recommended_milk %>
    <% drinks << "アイス" if review.recommended_iced %>

    <% if drinks.any? %>
      おすすめの飲み方：<%= drinks.join(" / ") %>
    <% end %>

  </div>

  <% if review.comment.present? %>
    <p class="mt-2"><%= review.comment %></p>
  <% end %>

</div>
