<div class="bg-[#FDFBF9] border-2 border-[#D6CEC5] rounded-2xl p-6 md:p-8 mb-8 shadow-sm relative overflow-hidden group">
  
  <%# 左側のアクセントしおり %>
  <div class="absolute left-0 top-0 w-1.5 h-full bg-[#365442] opacity-30 group-hover:opacity-100 transition-opacity duration-500"></div>

  <%# 上段：Overall（左）と 投稿者（右）を入れ替え %>
  <div class="flex justify-between items-end mb-6">
    <div class="flex flex-col">
      <span class="text-[15px] font-bold text-[#433D3C] tracking-[0.1em] uppercase mb-1">おすすめ度</span>
      <div class="flex items-center gap-2">
        <span class="text-[#C5A065] text-2xl leading-none"><%= render_stars(review.overall_rating) %></span>
      </div>
    </div>
    <div class="text-right">
      <span class="block font-serif font-bold text-sm text-[#365442] tracking-wide"><%= review.user.name %></span>
      <span class="text-[11px] text-[#8C7B6C] font-mono"><%= review.created_at.strftime("%Y.%m.%d") %></span>
    </div>
  </div>

  <%# 詳細評価：背景色をつけて密度感をアップ %>
  <div class="grid grid-cols-2 md:grid-cols-4 gap-2 mb-6 bg-[#F2F4F0]/50 rounded-xl p-4 border border-[#365442]/5">
    <% [
      ["香り", review.aroma_rating],
      ["渋み", review.bitterness_rating],
      ["濃さ", review.strength_rating],
      ["甘さ", review.sweetness_rating]
    ].each do |label, rating| %>
      <div class="flex flex-col items-center justify-center py-1">
        <span class="text-sm font-bold text-[#433D3C] mb-1"><%= label %></span>
        <span class="text-[#C5A065] text-sm"><%= render_stars(rating) %></span>
      </div>
    <% end %>
  </div>

  <%# おすすめの飲み方：タグ風 %>
  <div class="flex flex-wrap items-center gap-x-4 gap-y-2 mb-6">
    <%# ラベル部分 %>
    <span class="text-xs font-bold text-[#433D3C] tracking-wider flex-shrink-0">おすすめの飲み方</span>

    <%# タグを表示するコンテナ %>
    <div class="flex flex-wrap gap-2">
      <% drinks = [] %>
      <% drinks << "ストレート" if review.recommended_straight %>
      <% drinks << "ミルク" if review.recommended_milk %>
      <% drinks << "アイス" if review.recommended_iced %>

      <% drinks.each do |drink| %>
        <span class="px-3 py-1 bg-white border border-[#D6CEC5] text-[#A75F29] text-[13px] font-bold rounded shadow-sm">
          # <%= drink %>
        </span>
      <% end %>
    </div>
  </div>

  <%# コメント：文字サイズを大きくし、背景と引用符で埋める %>
  <% if review.comment.present? %>
    <div class="relative bg-white/60 border-l-4 border-[#D6CEC5] p-5 rounded-r-xl">
      <p class="text-[#433D3C] text-base md:text-lg leading-relaxed font-medium">
        <%= review.comment %>
      </p>
    </div>
  <% end %>
</div>