<div class="border rounded p-3 mb-3">

  <div class="text-sm text-gray-500">
    <%= review.user.name %> /
    <%= review.created_at.strftime("%Y.%m.%d") %>
  </div>

  <div class="mt-2 space-y-1">
    <div>おすすめ度 ⭐ <%= review.overall_rating %></div>
    <div>香り ⭐ <%= review.aroma_rating %></div>
    <div>渋み ⭐ <%= review.bitterness_rating %></div>
    <div>濃さ ⭐ <%= review.strength_rating %></div>
    <div>甘さ ⭐ <%= review.sweetness_rating %></div>
  </div>

  <% if review.comment.present? %>
    <p class="mt-2"><%= review.comment %></p>
  <% end %>

</div>
