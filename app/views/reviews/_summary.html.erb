<% summary = @review_summary %>
<div class="space-y-2">

  <h3 class="font-semibold text-lg">
    総合評価
  </h3>

  <div>
    おすすめ度
    <span class="text-yellow-500">
      <%= render_stars(summary.overall_avg.to_f.round) %>
    </span>
    (<%= number_with_precision(summary.overall_avg, precision: 1) %>)
  </div>

  <div>
    香り
    <span class="text-yellow-500">
      <%= render_stars(summary.aroma_avg.to_f.round) %>
    </span>
    (<%= number_with_precision(summary.aroma_avg, precision: 1) %>)
  </div>

  <div>
    渋み
    <span class="text-yellow-500">
      <%= render_stars(summary.bitterness_avg.to_f.round) %>
    </span>
    (<%= number_with_precision(summary.bitterness_avg, precision: 1) %>)
  </div>

  <div>
    濃さ
    <span class="text-yellow-500">
      <%= render_stars(summary.strength_avg.to_f.round) %>
    </span>
    (<%= number_with_precision(summary.strength_avg, precision: 1) %>)
  </div>

  <div>
    甘さ
    <span class="text-yellow-500">
      <%= render_stars(summary.sweetness_avg.to_f.round) %>
    </span>
    (<%= number_with_precision(summary.sweetness_avg, precision: 1) %>)
  </div>

</div>

   <% if summary.review_count.to_i > 0 %>

    <div class="mt-3">

      <div class="font-semibold">
        おすすめの飲み方
      </div>

      <div class="text-sm space-y-1">

        <div>
          ストレート
          <%= (summary.recommended_straight_count * 100 / summary.review_count.to_f).round %>%
          （<%= summary.recommended_straight_count %>件）
        </div>

        <div>
          ミルク
          <%= (summary.recommended_milk_count * 100 / summary.review_count.to_f).round %>%
          （<%= summary.recommended_milk_count %>件）
        </div>

        <div>
          アイス
          <%= (summary.recommended_iced_count * 100 / summary.review_count.to_f).round %>%
          （<%= summary.recommended_iced_count %>件）
        </div>

      </div>

    </div>

  <% end %>

</div>
