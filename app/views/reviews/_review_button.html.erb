<div class="py-2 flex justify-center">

  <% if current_user.nil? %>
    <%# 未ログイン：記録を書く %>
    <%= link_to new_user_session_path(review_required: true),
          class: "group flex items-center gap-2 sm:gap-3 bg-[#365442] text-[#F9F7F2] px-4 py-2.5 sm:px-8 sm:py-4 rounded-lg sm:rounded-xl font-serif font-bold tracking-[0.1em] sm:tracking-[0.15em] shadow-md sm:shadow-lg hover:bg-[#2A4034] transition-all border-b-2 sm:border-b-4 border-[#1e3126] active:border-b-0 active:translate-y-0.5 text-sm sm:text-base" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 sm:h-5 sm:w-5 opacity-70" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
      </svg>
      <span>記録を書く</span>
    <% end %>

  <% elsif user_review.present? %>
    <%# 投稿済み：編集する %>
    <%= link_to edit_tea_product_review_path(tea_product, user_review),
          data: { turbo_frame: "review_modal" },
          class: "group flex items-center gap-2 sm:gap-3 bg-white text-[#365442] border border-[#365442] sm:border-2 px-4 py-2.5 sm:px-8 sm:py-3.5 rounded-lg sm:rounded-xl font-serif font-bold tracking-[0.1em] sm:tracking-[0.15em] hover:bg-[#F2F4F0] transition-all shadow-sm text-xs sm:text-base" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 sm:h-5 sm:w-5 opacity-70" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
      </svg>
      <span>編集する</span>
    <% end %>

  <% else %>
    <%# 未投稿：記録を書く %>
    <%= link_to new_tea_product_review_path(tea_product),
          data: { turbo_frame: "review_modal" },
          class: "group flex items-center gap-2 sm:gap-3 bg-[#365442] text-[#F9F7F2] px-4 py-2.5 sm:px-8 sm:py-4 rounded-lg sm:rounded-xl font-serif font-bold tracking-[0.1em] sm:tracking-[0.15em] shadow-md sm:shadow-lg hover:bg-[#2A4034] transition-all border-b-2 sm:border-b-4 border-[#1e3126] active:border-b-0 active:translate-y-0.5 text-xs sm:text-base" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 sm:h-5 sm:w-5 opacity-70" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
      </svg>
      <span>記録を書く</span>
    <% end %>
  <% end %>

</div>